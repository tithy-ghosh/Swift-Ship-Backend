PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/swift-ship

# Firebase Admin SDK credentials
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Browser and SSLCommerz callback destinations
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Optional override when the allowed browser origin differs from FRONTEND_URL
CLIENT_URL=

# SSLCommerz sandbox credentials. Payment code is intentionally sandbox-only.
SSLCZ_STORE_ID=your-sandbox-store-id
SSLCZ_STORE_PASSWORD=your-sandbox-store-password
